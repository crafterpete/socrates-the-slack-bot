{
  "name": "langchain-slack-bot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Slack Q&A bot grounded in the Applied AI take-home SQLite database",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:tables": "tsx src/scripts/list-tables.ts",
    "eval": "tsx src/eval/run.ts",
    "eval:build-golden": "tsx src/eval/build-golden.ts",
    "eval:view": "tsx src/eval/view-report.ts",
    "eval:test": "node --import tsx --test src/eval/__tests__/*.test.ts src/db/__tests__/*.test.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@langchain/anthropic": "^1.5.1",
    "@langchain/core": "^1.1.0",
    "@langchain/langgraph": "^1.0.0",
    "@langchain/openai": "^1.1.0",
    "@slack/bolt": "^4.4.0",
    "better-sqlite3": "^11.10.0",
    "dotenv": "^16.6.1",
    "langchain": "^1.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.16.5",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
