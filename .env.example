# Anthropic API key (console.anthropic.com; billed from API credits, separate from a claude.ai subscription)
ANTHROPIC_API_KEY=

# Slack app credentials (https://api.slack.com/apps)
# OAuth client credentials so Bolt can rotate the bot token.
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# Socket Mode app-level token (does not expire, used for the WS connection).
SLACK_APP_TOKEN=xapp-...

# Only needed if you switch off Socket Mode to the HTTP Events API, to verify
# inbound request signatures. Unused in Socket Mode.
# SLACK_SIGNING_SECRET=

# Seed-only: the initial refresh token, consumed once by `npm run slack:seed` then safe to remove.
SLACK_BOT_REFRESH_TOKEN=xoxe-...

# Database path (relative to project root)
DATABASE_PATH=src/db/synthetic_startup.sqlite

# Optional model override (default claude-opus-4-8; e.g. claude-haiku-4-5 or claude-sonnet-5 for lower cost)
ANTHROPIC_MODEL=claude-opus-4-8
