# Anthropic API key (console.anthropic.com; billed from API credits, separate from a claude.ai subscription)
ANTHROPIC_API_KEY=

# OpenAI API key (platform.openai.com), used for embeddings only (semantic search over artifacts)
OPENAI_API_KEY=

# Slack tokens (https://api.slack.com/apps)
# Bot User OAuth Token from OAuth & Permissions (static, non-expiring).
SLACK_BOT_TOKEN=xoxb-...
# App-level token from Basic Information > App-Level Tokens (for Socket Mode).
SLACK_APP_TOKEN=xapp-...

# Database path (relative to project root)
DATABASE_PATH=src/db/synthetic_startup.sqlite

# Optional model override (default claude-opus-4-8; e.g. claude-haiku-4-5 or claude-sonnet-5 for lower cost)
ANTHROPIC_MODEL=claude-opus-4-8

# Optional embedding model override (default text-embedding-3-small)
EMBEDDING_MODEL=text-embedding-3-small

# Optional model for the log-only input classifier (default claude-haiku-4-5-20251001)
CLASSIFIER_MODEL=claude-haiku-4-5-20251001
